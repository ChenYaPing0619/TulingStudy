<Window x:Class="CommunityToolkitDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CommunityToolkitDemo"
        xmlns:viewmodels="clr-namespace:CommunityToolkitDemo.ViewModels"
        mc:Ignorable="d"
        Title="个人信息 - CommunityToolkit Demo"
        Height="620" Width="640"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        FontFamily="Microsoft YaHei UI">
    <Window.DataContext>
        <viewmodels:MainWindowViewModel />
    </Window.DataContext>

    <Window.Resources>
        <!-- 渐变背景 -->
        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A8C0FF" Offset="0"/>
            <GradientStop Color="#3F2B96" Offset="1"/>
        </LinearGradientBrush>

        <!-- 按钮背景渐变 -->
        <LinearGradientBrush x:Key="ButtonBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#667EEA" Offset="0"/>
            <GradientStop Color="#764BA2" Offset="1"/>
        </LinearGradientBrush>

        <!-- 按钮鼠标悬停渐变 -->
        <LinearGradientBrush x:Key="ButtonHoverBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#5568D3" Offset="0"/>
            <GradientStop Color="#653A91" Offset="1"/>
        </LinearGradientBrush>

        <!-- 按钮禁用渐变(浅灰) -->
        <LinearGradientBrush x:Key="ButtonDisabledBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E2E8F0" Offset="0"/>
            <GradientStop Color="#CBD5E0" Offset="1"/>
        </LinearGradientBrush>

        <!-- 主文字渐变 -->
        <LinearGradientBrush x:Key="PrimaryTextBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#667EEA" Offset="0"/>
            <GradientStop Color="#764BA2" Offset="1"/>
        </LinearGradientBrush>

        <!-- 头像背景渐变 -->
        <LinearGradientBrush x:Key="AvatarBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E0E7FF" Offset="0"/>
            <GradientStop Color="#C7D2FE" Offset="1"/>
        </LinearGradientBrush>

        <!-- 信息行样式 -->
        <Style x:Key="InfoRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,8"/>
        </Style>

        <!-- 标签样式 -->
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#718096"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 值样式 -->
        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2D3748"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 卡片样式 -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="40"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.25" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 头像圆形样式 -->
        <Style x:Key="AvatarBorder" TargetType="Border">
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="110"/>
            <Setter Property="CornerRadius" Value="55"/>
            <Setter Property="Background" Value="{StaticResource AvatarBackgroundBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.2" Color="#667EEA"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主按钮样式 -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="32,14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.3" Color="#5568D3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- 鼠标悬停 -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ButtonHoverBrush}"/>
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <!-- 按下 -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <!-- 禁用:浅灰渐变 + 淡色文字 + 整体半透明 + 不响应悬停 -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource ButtonDisabledBrush}"/>
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                <Setter Property="Foreground" Value="#A0AEC0"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 整体渐变背景 -->
    <Grid>
        <Grid.Background>
            <StaticResource ResourceKey="WindowBackgroundBrush"/>
        </Grid.Background>

        <!-- 居中卡片 -->
        <Border Style="{StaticResource CardBorder}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="420">
            <StackPanel HorizontalAlignment="Stretch">

                <!-- 标题 -->
                <TextBlock Text="👤 个人信息"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#2D3748"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>

                <!-- 副标题 -->
                <TextBlock Text="CommunityToolkit.Mvvm 演示"
                           FontSize="13"
                           Foreground="#718096"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"/>

                <!-- 头像 -->
                <Border Style="{StaticResource AvatarBorder}" Margin="0,0,0,24">
                    <TextBlock Text="{Binding Avatar}"
                               FontSize="60"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- 信息字段卡片 -->
                <Border Background="#F7FAFC"
                        CornerRadius="12"
                        Padding="20,16"
                        Margin="0,0,0,24">
                    <StackPanel>
                        <!-- 姓名 -->
                        <Grid Style="{StaticResource InfoRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="姓名" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}" Style="{StaticResource InfoValue}"/>
                        </Grid>

                        <!-- 分隔线 -->
                        <Rectangle Height="1" Fill="#E2E8F0" Margin="0,4"/>

                        <!-- 性别 -->
                        <Grid Style="{StaticResource InfoRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="性别" Style="{StaticResource InfoLabel}"/>
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <RadioButton Content="👨 男"
                                             GroupName="Gender"
                                             IsChecked="{Binding IsMale}"
                                             Command="{Binding SetGenderCommand}"
                                             CommandParameter="男"
                                             VerticalAlignment="Center"
                                             Margin="0,0,20,0"/>
                                <RadioButton Content="👩 女"
                                             GroupName="Gender"
                                             IsChecked="{Binding IsFemale}"
                                             Command="{Binding SetGenderCommand}"
                                             CommandParameter="女"
                                             VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <!-- 分隔线 -->
                        <Rectangle Height="1" Fill="#E2E8F0" Margin="0,4"/>

                        <!-- 年龄 -->
                        <Grid Style="{StaticResource InfoRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="年龄" Style="{StaticResource InfoLabel}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Age}" Style="{StaticResource InfoValue}"/>
                                <TextBlock Text=" 岁"
                                           FontSize="14"
                                           Foreground="#A0AEC0"
                                           VerticalAlignment="Bottom"
                                           Margin="4,0,0,2"/>
                                <CheckBox IsChecked="{Binding IsChecked}" Content="启用年龄增长" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 操作按钮 -->
                <Button Content="✨ 增长年龄 +1"
                        Command="{Binding IncreaseAgeCommand}"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Center"/>

                <!-- 底部说明 -->
                <TextBlock Text="点击按钮,年龄自动 +1 并实时更新"
                           FontSize="12"
                           Foreground="#A0AEC0"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>