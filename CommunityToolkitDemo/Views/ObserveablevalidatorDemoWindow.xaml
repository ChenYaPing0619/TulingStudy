<Window x:Class="CommunityToolkitDemo.Views.ObserveablevalidatorDemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CommunityToolkitDemo.Views"
        xmlns:viewModels="clr-namespace:CommunityToolkitDemo.ViewModels"
        mc:Ignorable="d"
        Title="数据验证演示 - ObservableValidator"
        Height="620" Width="640"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        FontFamily="Microsoft YaHei UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.DataContext>
        <viewModels:ObserveablevalidatorDemoViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- ========== 渐变画刷 ========== -->
        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#A8C0FF" Offset="0"/>
            <GradientStop Color="#3F2B96" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PrimaryBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#667EEA" Offset="0"/>
            <GradientStop Color="#764BA2" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PrimaryHoverBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#5568D3" Offset="0"/>
            <GradientStop Color="#653A91" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="IconBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E0E7FF" Offset="0"/>
            <GradientStop Color="#C7D2FE" Offset="1"/>
        </LinearGradientBrush>

        <!-- ========== 卡片样式 ========== -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="40,36"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.25" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== 字段标签 ========== -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2D3748"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- ========== 帮助文字(输入框下方) ========== -->
        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#A0AEC0"/>
            <Setter Property="Margin" Value="4,6,0,0"/>
        </Style>

        <!-- ========== 输入框容器(基础外观,无触发器) ========== -->
        <Style x:Key="InputBorderBase" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="#F7FAFC"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ========== 年龄输入框边框(只监听自身错误) ========== -->
        <Style x:Key="AgeInputBorder" TargetType="Border" BasedOn="{StaticResource InputBorderBase}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=AgeInput, Path=(Validation.HasError)}" Value="True">
                    <Setter Property="BorderBrush" Value="#F56565"/>
                    <Setter Property="Background" Value="#FFF5F5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ========== 邮箱输入框边框(只监听自身错误) ========== -->
        <Style x:Key="EmailInputBorder" TargetType="Border" BasedOn="{StaticResource InputBorderBase}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ElementName=EmailInput, Path=(Validation.HasError)}" Value="True">
                    <Setter Property="BorderBrush" Value="#F56565"/>
                    <Setter Property="Background" Value="#FFF5F5"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ========== 现代化 TextBox ========== -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="#2D3748"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="#667EEA"/>
            <Setter Property="SelectionBrush" Value="#667EEA"/>
            <Setter Property="Padding" Value="0,12"/>
        </Style>

        <!-- ========== 主按钮 ========== -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="36,14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.3" Color="#5568D3"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.04" ScaleY="1.04"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ========== 验证错误模板 ========== -->
        <ControlTemplate x:Key="ValidationErrorTemplate">
            <Grid>
                <AdornedElementPlaceholder x:Name="Placeholder"/>
            </Grid>
        </ControlTemplate>
    </Window.Resources>

    <!-- ========== 整体渐变背景 ========== -->
    <Grid>
        <Grid.Background>
            <StaticResource ResourceKey="WindowBackgroundBrush"/>
        </Grid.Background>

        <!-- ========== 居中卡片 ========== -->
        <Border Style="{StaticResource CardBorder}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="460">

            <StackPanel>

                <!-- 顶部图标徽章 -->
                <Border Width="64" Height="64"
                        CornerRadius="32"
                        Background="{StaticResource IconBackgroundBrush}"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.2" Color="#667EEA"/>
                    </Border.Effect>
                    <TextBlock Text="🛡️"
                               FontSize="32"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- 标题 -->
                <TextBlock Text="数据验证演示"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="#2D3748"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>

                <!-- 副标题 -->
                <TextBlock Text="ObservableValidator + DataAnnotations"
                           FontSize="13"
                           Foreground="#718096"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32"/>

                <!-- ========== 年龄字段 ========== -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🎂 年龄" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Grid.Column="1" Text="必填"
                               FontSize="11"
                               Foreground="#F56565"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>

                <Border Style="{StaticResource AgeInputBorder}">
                    <TextBox x:Name="AgeInput"
                             Text="{Binding Age, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                             Validation.ErrorTemplate="{StaticResource ValidationErrorTemplate}"
                             Style="{StaticResource ModernTextBox}"/>
                </Border>

                <!-- 年龄提示/错误信息 -->
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource FieldHint}">
                            <Setter Property="Text" Value="请输入 0 ~ 120 之间的整数"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=AgeInput, Path=(Validation.HasError)}" Value="True">
                                    <Setter Property="Text" Value="{Binding ElementName=AgeInput, Path=(Validation.Errors)[0].ErrorContent}"/>
                                    <Setter Property="Foreground" Value="#E53E3E"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Grid Height="20"/>

                <!-- ========== 邮箱字段 ========== -->
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="📧 邮箱" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Grid.Column="1" Text="必填"
                               FontSize="11"
                               Foreground="#F56565"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </Grid>

                <Border Style="{StaticResource EmailInputBorder}">
                    <TextBox x:Name="EmailInput"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                             Validation.ErrorTemplate="{StaticResource ValidationErrorTemplate}"
                             Style="{StaticResource ModernTextBox}"/>
                </Border>

                <!-- 邮箱提示/错误信息 -->
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource FieldHint}">
                            <Setter Property="Text" Value="例如:example@domain.com"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=EmailInput, Path=(Validation.HasError)}" Value="True">
                                    <Setter Property="Text" Value="{Binding ElementName=EmailInput, Path=(Validation.Errors)[0].ErrorContent}"/>
                                    <Setter Property="Foreground" Value="#E53E3E"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Grid Height="32"/>

                <!-- ========== 提交按钮 ========== -->
                <Button Content="✅  提交验证"
                        Command="{Binding SubmitCommand}"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Center"
                        MinWidth="200"/>
                
                <!-- ========== 底部说明 ========== -->
                <TextBlock Text="{Binding ErrorMessage}"
                           FontSize="12"
                           Foreground="#A0AEC0"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,0"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>