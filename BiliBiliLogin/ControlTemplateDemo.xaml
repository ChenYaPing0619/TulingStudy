<Window x:Class="BiliBiliLogin.ControlTemplateDemo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BiliBiliLogin"
        mc:Ignorable="d"
        Title="ControlTemplateDemo" Height="450" Width="800">
    <Window.Resources>
        <ControlTemplate x:Key="BtnTemplate" TargetType="Button">
            <StackPanel>
                <Button Content="{TemplateBinding Property=Content}"/>
                <TextBlock Text="{TemplateBinding Property=Tag}"/>
            </StackPanel>
        </ControlTemplate>
        <Style TargetType="{x:Type Window}">
            <Setter Property="FontFamily" Value="Arial Black"/>
        </Style>
        <Style TargetType="{x:Type Page}">
            <Setter Property="FontFamily" Value="Arial Black"/>
        </Style>
        <Style TargetType="{x:Type UserControl}">
            <Setter Property="FontFamily" Value="Arial Black"/>
        </Style>
    </Window.Resources>
    <Grid>
        <StackPanel Orientation="Vertical" >
            <Button Template="{StaticResource BtnTemplate}" Height="50" Width="100" Margin="0,10,0,10"
                    Content="登录" Tag="请输入账号密码"/>
            <Button Style="{DynamicResource ButtonStyle1}" Content="切换" Height="50" Width="100"/>
        </StackPanel>
    </Grid>
</Window>
