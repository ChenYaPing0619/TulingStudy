<Window x:Class="BindingDemo.BindingSourceByRelative"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BindingDemo"
        mc:Ignorable="d"
        Title="BindingSourceByRelative" Height="450" Width="800">
    <Grid Background="LightBlue">
        <!--绑定到自身-->
        <StackPanel Background="CadetBlue" Width="200" Height="{Binding RelativeSource={RelativeSource Mode=Self}, Path=Width}">
            <!--绑定到父元素-->
            <Button Content="Relative" Margin="20" Background="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Grid}}, Path=Background}"/>
        </StackPanel>
        
    </Grid>
</Window>
