<Window x:Class="BindingDemo.ConvertListDemo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BindingDemo"
        mc:Ignorable="d"
      
        Title="ConvertListDemo" Height="450" Width="800">
    <Window.Resources>
        <local:IconsConvert x:Key="IconsConvertTool"/>
    </Window.Resources>
    <Grid>
        <ListBox Name="UserListBox">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Name}" Margin="5"/>
                        <TextBlock Text="{Binding Score}" Margin="5"/>
                        <Image Source="{Binding Icon, Converter={StaticResource IconsConvertTool}}" Width="32" Height="32" Margin="5"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
