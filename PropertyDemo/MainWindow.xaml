<Window x:Class="PropertyDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PropertyDemo"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>

        </Grid.ColumnDefinitions>
        <Canvas Grid.Column="0">
            <Label Content="附件属性" HorizontalAlignment="Center"/>
            <Slider x:Name="SliderX" Minimum="0" Maximum="100" Value="50" Width="200" Height="30" Canvas.Left="10" Canvas.Top="20"/>
            <Slider x:Name="SliderY" Minimum="0" Maximum="100" Value="50" Width="200" Height="30" Canvas.Left="10" Canvas.Top="40"/>
            <Rectangle x:Name="MyRectangle" Width="50" Height="50" Fill="Blue" Canvas.Left="{Binding ElementName=SliderX, Path=Value}" Canvas.Top="{Binding ElementName=SliderY, Path=Value}"/>
        </Canvas>
        <Grid Grid.Column="1">
            <StackPanel>
                <Label Content="依赖属性" HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal">
                   <Button Content="+" Width="80" Click="ButtonSetPlus_Click"/>
                    <Button Content="-" Width="80" Click="ButtonSetMinus_Click"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Label Content="Age属性值:"/>
                    <TextBox x:Name="TextBoxAge" Width="50" VerticalContentAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
