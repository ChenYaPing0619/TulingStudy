<Window x:Class="PropertyDemo.ControlAlarm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PropertyDemo"
        mc:Ignorable="d"
        Title="ControlAlarm" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="30,20,10,20">
            <TextBox x:Name="AlarmText1" Width="180" Height="32" Text="温度: 95℃"
                     local:AlarmAttached.IsAlarm="True"/>
            <TextBox x:Name="AlarmText2" Width="180" Height="32" Margin="0,10,0,0" Text="温度: 45℃"
                     local:AlarmAttached.IsAlarm="False"/>

            <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                <Button Width="100" Height="32" Content="全部报警" Click="SetAlarmButton_Click"/>
                <Button Width="100" Height="32" Margin="10,0,0,0" Content="全部恢复" Click="ClearAlarmButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
