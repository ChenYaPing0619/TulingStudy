<Window x:Class="RouterDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RouterDemo"
        mc:Ignorable="d"
        Title="路由事件演示" Height="460" Width="820">
    <Grid x:Name="RootGrid" Margin="12"
          PreviewMouseDown="RootGrid_PreviewMouseDown"
          MouseDown="RootGrid_MouseDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <Border x:Name="DemoBorder" Grid.Column="0" Padding="16" BorderBrush="Gray" BorderThickness="1"
                PreviewMouseDown="DemoBorder_PreviewMouseDown"
                MouseDown="DemoBorder_MouseDown">
            <StackPanel>
                <TextBlock Text="点击下面区域观察事件路由（更稳定演示 MouseDown）" Margin="0,0,0,12"/>
                <Border x:Name="DemoButton" Width="120" Height="36" Background="#FF4D89F9" CornerRadius="4"
                        PreviewMouseDown="DemoButton_PreviewMouseDown"
                        MouseDown="DemoButton_MouseDown">
                    <TextBlock Text="点击区域" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>
        </Border>

        <GroupBox Grid.Column="1" Header="事件日志" Margin="12,0,0,0">
            <ListBox x:Name="LogList"/>
        </GroupBox>
    </Grid>
</Window>
